# Database Configuration
POSTGRES_USER=conductor_admin
POSTGRES_PASSWORD=conductor_dev_password
POSTGRES_DB=postgres
POSTGRES_PORT=5433

# Database Connection URL for Backend
DATABASE_URL=postgresql://conductor_admin:conductor_dev_password@localhost:5433/conductor_tool

# PgAdmin Configuration (Optional - Web UI for database management)
# Access at http://localhost:5050
PGADMIN_EMAIL=admin@conductor.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Backend Configuration
NODE_ENV=development
PORT=3000
