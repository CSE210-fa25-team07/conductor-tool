# Conductor Tool - Environment Configuration
# Copy this file to .env and update the values as needed

# PostgreSQL Database Configuration
POSTGRES_DB=conductor
POSTGRES_USER=conductor_user
POSTGRES_PASSWORD=conductor_pass
POSTGRES_PORT=5432

# PgAdmin Configuration (Optional - Web UI for database management)
# Access at http://localhost:5050
PGADMIN_EMAIL=admin@conductor.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Database Connection String (for application use)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://conductor_user:conductor_pass@localhost:5432/conductor
